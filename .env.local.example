# Vendor Performance Intelligence Engine — LOCAL DEV environment overrides.
#
# Copy this file to `.env.local` (git-ignored) to feed docker-compose.yml.
# Values below override the production-shaped `.env.example` for compose-DNS
# service names (postgres, redis, nats) and disable every ecosystem flag so the
# core engine runs fully standalone (PRD §2.2).
#
# The dev compose stack also injects DATABASE_URL / REDIS_URL / RAILS_ENV via
# the `environment:` block, so these serve as the canonical reference + safe
# defaults if you run bare `docker compose run --rm dev` commands.

# ---------------------------------------------------------------------------
# Rails
# ---------------------------------------------------------------------------
RAILS_ENV=development
RAILS_LOG_LEVEL=debug
# After `rails new`, copy the 32-hex-char value of config/master.key here.
# Both config/master.key and .env.local are gitignored.
RAILS_MASTER_KEY=copy_32_hex_chars_from_config_master_key
# Leave blank in dev/test — Rails derives SECRET_KEY_BASE from credentials.
# Production sets this explicitly from a secret manager.
SECRET_KEY_BASE=
PORT=3000

# ---------------------------------------------------------------------------
# Database / Redis — use compose service DNS names
# ---------------------------------------------------------------------------
DATABASE_URL=postgresql://vpi_user:vpi_dev_pw@postgres:5432/vpi_development
DATABASE_POOL=5
REDIS_URL=redis://redis:6379/0
SIDEKIQ_CONCURRENCY=2

# ---------------------------------------------------------------------------
# Tenant Management
# ---------------------------------------------------------------------------
SELF_REGISTRATION_ENABLED=true
API_KEY_PREFIX=vpi

# ---------------------------------------------------------------------------
# Auth / Security
# ---------------------------------------------------------------------------
ALLOWED_ORIGINS=http://localhost:3000
HUB_INGRESS_SECRET=dev_hmac_secret_not_for_production

# ---------------------------------------------------------------------------
# Scoring tunables
# ---------------------------------------------------------------------------
DEFAULT_WINDOW_DAYS=90
DEFAULT_TIME_DECAY_HALF_LIFE_DAYS=45
ALERT_DEDUP_WINDOW_HOURS=24
MAX_SIGNAL_BACKFILL_DAYS=365
INGESTION_BATCH_SIZE=100
SCORER_MAX_SIGNALS_PER_COMPUTE=10000
AUTO_MATCH_FUZZY_THRESHOLD=2
AUTO_CONFIRM_EXACT_TAXID=true

# ---------------------------------------------------------------------------
# Setup automation
# ---------------------------------------------------------------------------
AUTO_SEED=true
AUTO_MIGRATE=true

# ---------------------------------------------------------------------------
# Ecosystem integrations — ALL DISABLED by default (standalone-first, PRD §2.2)
# ---------------------------------------------------------------------------
NOTIFICATION_HUB_ENABLED=false
NOTIFICATION_HUB_URL=http://notification-hub:3000
NOTIFICATION_HUB_API_KEY=dev_key

WORKFLOW_ENGINE_ENABLED=false
WORKFLOW_ENGINE_URL=http://workflow-engine:3000
WORKFLOW_ENGINE_API_KEY=dev_key

WEBHOOK_ENGINE_ENABLED=false
WEBHOOK_ENGINE_URL=http://webhook-engine:3000
WEBHOOK_ENGINE_API_KEY=dev_key

INVOICE_RECON_ENABLED=false
INVOICE_RECON_URL=http://invoice-recon:3000
INVOICE_RECON_API_KEY=dev_key

CONTRACT_ENGINE_ENABLED=false
CONTRACT_ENGINE_URL=http://contract-engine:5000
CONTRACT_ENGINE_API_KEY=dev_key

NATS_ENABLED=false
NATS_URL=nats://nats:4222
NATS_CREDS_PATH=
NATS_STREAM_NAME=CONTRACT_LIFECYCLE

RECON_ENGINE_ENABLED=false
RECON_ENGINE_URL=http://recon-engine:3000
RECON_ENGINE_API_KEY=dev_key

RAG_PLATFORM_ENABLED=false
RAG_PLATFORM_URL=http://rag-platform:3000
RAG_PLATFORM_API_KEY=dev_key

# ---------------------------------------------------------------------------
# Observability — disabled locally
# ---------------------------------------------------------------------------
SENTRY_DSN=
AXIOM_TOKEN=
AXIOM_DATASET=vpi-development
POSTHOG_API_KEY=
POSTHOG_HOST=
PROMETHEUS_ENABLED=false
METRICS_BASIC_AUTH_USER=metrics
METRICS_BASIC_AUTH_PASS=dev

# ---------------------------------------------------------------------------
# Report generation
# ---------------------------------------------------------------------------
REPORT_RETENTION_DAYS=30
PDF_RENDER_TIMEOUT_SECONDS=30
REPORT_STORAGE_PATH=/app/tmp/reports
