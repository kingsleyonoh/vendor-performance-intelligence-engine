<% content_for :title, "Edit #{@source.source_system} — Ingestion Sources" %>

<div class="max-w-2xl space-y-4">
  <header>
    <h1 class="text-2xl font-bold text-gray-900">Edit <%= @source.source_system %></h1>
    <p class="text-sm text-gray-500">
      <%= link_to "← Back", settings_ingestion_source_path(@source),
            class: "text-sm text-gray-600 hover:underline" %>
    </p>
  </header>

  <div class="bg-white rounded-lg shadow-sm p-4">
    <%= render Settings::IngestionSourceFormComponent.new(source: @source, mode: :edit) %>
  </div>
</div>
