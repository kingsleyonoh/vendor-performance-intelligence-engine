<% content_for :title, "New ingestion source — #{UiBrand.display_name_for(Current.tenant)}" %>

<div class="max-w-2xl space-y-4">
  <header>
    <h1 class="text-2xl font-bold text-gray-900">New ingestion source</h1>
    <p class="text-sm text-gray-500">Configure an upstream adapter for <%= UiBrand.display_name_for(Current.tenant) %>.</p>
  </header>

  <div class="bg-white rounded-lg shadow-sm p-4">
    <%= render Settings::IngestionSourceFormComponent.new(source: @source, mode: :new) %>
  </div>
</div>
