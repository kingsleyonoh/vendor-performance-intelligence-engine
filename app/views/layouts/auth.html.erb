<!DOCTYPE html>
<html style="--brand-primary: <%= UiBrand.primary_for(Current.tenant) %>; --brand-accent: <%= UiBrand.accent_for(Current.tenant) %>;">
  <head>
    <title><%= content_for(:title) || "VPI — Sign in" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
  </head>
  <body class="min-h-screen" style="background-color: var(--brand-primary); color: #F7FAFC;">
    <main class="flex items-center justify-center min-h-screen px-5">
      <div class="w-full max-w-md rounded-xl shadow-xl p-8" style="background-color: #1A202C;">
        <h1 class="text-2xl font-bold mb-6 text-center" style="color: var(--brand-accent);">
          Vendor Performance Intelligence
        </h1>
        <%= yield %>
      </div>
    </main>
  </body>
</html>
