<tr class="border-t" data-testid="source-row" data-source-system="<%= source.source_system %>">
  <td class="px-3 py-2 text-sm">
    <%= link_to source.source_system, helpers.settings_ingestion_source_path(source),
          class: "font-medium text-gray-900 hover:underline",
          data: { testid: "source-link" } %>
    <div class="text-xs text-gray-500"><%= source.pull_mode %></div>
  </td>
  <td class="px-3 py-2 text-sm">
    <%= source.is_enabled ? "Yes" : "No" %>
  </td>
  <td class="px-3 py-2 text-sm text-gray-700">
    <%= last_pull_label %>
  </td>
  <td class="px-3 py-2 text-sm">
    <span class="inline-block px-2 py-0.5 rounded-full text-xs font-medium"
          style="background-color: <%= status_color %>; color: <%= status_text_color %>;"
          data-testid="status-pill">
      <%= status_label %>
    </span>
  </td>
  <td class="px-3 py-2 text-sm text-right space-x-2">
    <%= link_to "Edit", helpers.edit_settings_ingestion_source_path(source),
          class: "text-sm text-gray-700 hover:underline" %>
    <%= button_to "Pull Now", helpers.pull_now_settings_ingestion_source_path(source),
          method: :post,
          class: "inline-flex rounded-md px-2 py-1 text-xs font-medium text-white",
          style: "background-color: var(--brand-accent);",
          data: { testid: "pull-now-btn" } %>
  </td>
</tr>
