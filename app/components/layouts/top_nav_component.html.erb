<header data-testid="app-top-nav" class="flex items-center justify-between px-6 py-3 shadow-sm"
        style="background-color: var(--brand-primary); color: #F7FAFC;">
  <div class="flex items-center gap-3">
    <span class="text-lg font-bold" style="color: var(--brand-accent);">VPI</span>
    <span class="text-sm opacity-80">/</span>
    <span class="text-base font-medium" data-testid="tenant-display-name"><%= tenant_display_name %></span>
  </div>

  <div class="flex items-center gap-4 text-sm">
    <% if user %>
      <span class="opacity-80" data-testid="user-email"><%= user.email_address %></span>
    <% end %>
    <%= button_to "Sign out", session_path,
          method: :delete,
          class: "rounded-md px-3 py-1 text-sm font-medium",
          style: "background-color: var(--brand-accent); color: white;" %>
  </div>
</header>
