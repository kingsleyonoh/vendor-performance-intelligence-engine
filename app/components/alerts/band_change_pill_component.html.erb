<span class="inline-flex items-center gap-1 text-xs font-semibold" data-testid="band-change-pill"
      data-previous-band="<%= previous_band %>" data-new-band="<%= new_band %>">
  <span class="inline-block rounded-full px-2 py-0.5 text-white" style="background-color: <%= previous_color %>;">
    <%= previous_band %>
  </span>
  <span class="text-gray-400">&rarr;</span>
  <span class="inline-block rounded-full px-2 py-0.5 text-white" style="background-color: <%= new_color %>;">
    <%= new_band %>
  </span>
</span>
