# Vendor Performance Intelligence Engine — Environment Variables
# Copy to `.env` on the server and replace placeholder values.
# ⛔ NEVER commit the real `.env` — only `.env.example` is git-tracked.

# ---------------------------------------------------------------------------
# Rails
# ---------------------------------------------------------------------------
RAILS_ENV=production
RAILS_LOG_LEVEL=info
RAILS_MASTER_KEY=xxxxx
SECRET_KEY_BASE=xxxxx
PORT=3000

# ---------------------------------------------------------------------------
# Database (PostgreSQL 16 + pg_partman)
# ---------------------------------------------------------------------------
DATABASE_URL=postgresql://vpi_user:changeme@postgres:5432/vpi_production
DATABASE_POOL=10

# ---------------------------------------------------------------------------
# Redis / Sidekiq
# ---------------------------------------------------------------------------
REDIS_URL=redis://redis:6379/0
SIDEKIQ_CONCURRENCY=5

# ---------------------------------------------------------------------------
# Tenant Management (MANDATORY)
# ---------------------------------------------------------------------------
SELF_REGISTRATION_ENABLED=true       # true for self-hosted, false for managed
API_KEY_PREFIX=vpi                   # results in keys like vpi_live_...

# ---------------------------------------------------------------------------
# Auth / Security
# ---------------------------------------------------------------------------
ALLOWED_ORIGINS=https://vendors.kingsleyonoh.com
HUB_INGRESS_SECRET=xxxxx             # 32-byte hex; HMAC secret for Hub → /api/signals/from-hub

# ---------------------------------------------------------------------------
# Scoring defaults (overrideable per tenant via scoring_rules)
# ---------------------------------------------------------------------------
DEFAULT_WINDOW_DAYS=90
DEFAULT_TIME_DECAY_HALF_LIFE_DAYS=45
ALERT_DEDUP_WINDOW_HOURS=24
MAX_SIGNAL_BACKFILL_DAYS=365
INGESTION_BATCH_SIZE=100
SCORER_MAX_SIGNALS_PER_COMPUTE=10000
AUTO_MATCH_FUZZY_THRESHOLD=2
AUTO_CONFIRM_EXACT_TAXID=true

# ---------------------------------------------------------------------------
# Setup automation
# ---------------------------------------------------------------------------
AUTO_SEED=true                       # run vpi:setup on first boot
AUTO_MIGRATE=true                    # run db:migrate on boot

# ---------------------------------------------------------------------------
# Notification Hub (optional — enable to emit alerts)
# ---------------------------------------------------------------------------
NOTIFICATION_HUB_ENABLED=false
NOTIFICATION_HUB_URL=https://notify.kingsleyonoh.com
NOTIFICATION_HUB_API_KEY=xxxxx

# ---------------------------------------------------------------------------
# Workflow Automation Engine (optional — HIGH/CRITICAL escalations)
# ---------------------------------------------------------------------------
WORKFLOW_ENGINE_ENABLED=false
WORKFLOW_ENGINE_URL=https://workflows.kingsleyonoh.com
WORKFLOW_ENGINE_API_KEY=xxxxx

# ---------------------------------------------------------------------------
# Webhook Ingestion Engine (optional — integration-reliability signals)
# ---------------------------------------------------------------------------
WEBHOOK_ENGINE_ENABLED=false
WEBHOOK_ENGINE_URL=https://webhooks.kingsleyonoh.com
WEBHOOK_ENGINE_API_KEY=xxxxx

# ---------------------------------------------------------------------------
# Invoice Reconciliation Engine (optional — financial signals)
# ---------------------------------------------------------------------------
INVOICE_RECON_ENABLED=false
INVOICE_RECON_URL=https://invoices.kingsleyonoh.com
INVOICE_RECON_API_KEY=xxxxx

# ---------------------------------------------------------------------------
# Contract Lifecycle Engine (optional — contractual signals; REST backfill)
# ---------------------------------------------------------------------------
CONTRACT_ENGINE_ENABLED=false
CONTRACT_ENGINE_URL=http://contract-engine:5000
CONTRACT_ENGINE_API_KEY=xxxxx

# ---------------------------------------------------------------------------
# NATS (optional — Contract Lifecycle JetStream consumer)
# ---------------------------------------------------------------------------
NATS_ENABLED=false
NATS_URL=nats://nats.kingsleyonoh.com:4222
NATS_CREDS_PATH=/etc/vpi/nats.creds
NATS_STREAM_NAME=CONTRACT_LIFECYCLE

# ---------------------------------------------------------------------------
# Transaction Reconciliation Engine (optional — transactional signals)
# ---------------------------------------------------------------------------
RECON_ENGINE_ENABLED=false
RECON_ENGINE_URL=https://recon-engine.kingsleyonoh.com
RECON_ENGINE_API_KEY=xxxxx

# ---------------------------------------------------------------------------
# RAG Platform (optional — vendor context enrichment)
# ---------------------------------------------------------------------------
RAG_PLATFORM_ENABLED=false
RAG_PLATFORM_URL=https://ai.kingsleyonoh.com
RAG_PLATFORM_API_KEY=xxxxx

# ---------------------------------------------------------------------------
# Observability (optional)
# ---------------------------------------------------------------------------
SENTRY_DSN=
AXIOM_TOKEN=xxxxx
AXIOM_DATASET=vpi-production
POSTHOG_API_KEY=xxxxx
POSTHOG_HOST=https://posthog.kingsleyonoh.com
PROMETHEUS_ENABLED=true
METRICS_BASIC_AUTH_USER=metrics
METRICS_BASIC_AUTH_PASS=changeme

# ---------------------------------------------------------------------------
# Report generation
# ---------------------------------------------------------------------------
REPORT_RETENTION_DAYS=30
PDF_RENDER_TIMEOUT_SECONDS=30
REPORT_STORAGE_PATH=/var/vpi/reports
